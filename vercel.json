{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/index.js"
    },
    {
      "src": "/sign/(.*)",
      "dest": "server/index.js"
    },
    {
      "src": "/reset-password/(.*)",
      "dest": "server/index.js"
    },
    {
      "src": "/public/(.*)",
      "dest": "server/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "server/index.js"
    }
  ]
}
